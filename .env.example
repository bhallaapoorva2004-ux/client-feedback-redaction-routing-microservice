# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPPORT_DB_URL: Destination endpoint database URL for negative/neutral customer feedback.
SUPPORT_DB_URL="MY_SUPPORT_DB_URL"

# MARKETING_DB_URL: Destination endpoint database URL for positive customer feedback.
MARKETING_DB_URL="MY_MARKETING_DB_URL"
